# Database
DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/socioeducativo"

# JWT
JWT_SECRET="cambiar-esto-por-un-secret-seguro-de-64-caracteres"
JWT_REFRESH_SECRET="cambiar-esto-por-otro-secret-seguro-de-64-caracteres"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:5173"

# Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
