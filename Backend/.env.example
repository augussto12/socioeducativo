# Database
DATABASE_URL="postgresql://postgres:replace-with-password@localhost:5432/socioeducativo?schema=public"

# JWT
JWT_ACCESS_SECRET="replace-with-long-random-access-secret-64-chars-min"
JWT_REFRESH_SECRET="replace-with-long-random-refresh-secret-64-chars-min"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
ADMIN_EMAIL="admin@socioeducativo.local"
ADMIN_PASSWORD="replace-before-production"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Cookies
COOKIE_DOMAIN=""
COOKIE_SECURE=false
COOKIE_SAME_SITE="lax"

# Uploads
UPLOAD_DIR="./uploads"
UPLOAD_PUBLIC_DIR="./uploads/public"
UPLOAD_PRIVATE_DIR="./uploads/private"
MAX_FILE_SIZE=5242880
MAX_IMAGE_SIZE=10485760
MAX_DOCUMENT_SIZE=26214400
MAX_AUDIO_SIZE=52428800
MAX_VIDEO_SIZE=262144000
