generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  FINISHED
  ARCHIVED
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum RecordStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum RecordType {
  ACTIVITY
  EVIDENCE
  PLANNING
  REFLECTION
  EVALUATION
  OTHER
}

enum FileType {
  IMAGE
  VIDEO
  AUDIO
  PDF
  DOCUMENT
  OTHER
}

model User {
  id                 String    @id @default(uuid())
  name               String    @db.VarChar(150)
  email              String    @unique @db.VarChar(180)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  role               UserRole  @default(STAFF)
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  projectMemberships ProjectMember[]
  createdRecords     ProjectRecord[] @relation("RecordAuthor")
  reviewedRecords    ProjectRecord[] @relation("RecordReviewer")
  uploadedFiles      RecordFile[]    @relation("FileUploader")
  auditLogs          AuditLog[]
  siteContentUpdates SiteContent[]   @relation("SiteContentUpdatedBy")
  refreshSessions    RefreshSession[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model RefreshSession {
  id        String    @id
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_sessions")
}

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique @db.VarChar(100)
  title     String   @db.VarChar(200)
  content   String   @db.Text
  imageUrl  String?  @map("image_url") @db.VarChar(500)
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  updatedByUser User? @relation("SiteContentUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("site_contents")
}

model PedagogicalProject {
  id                    String        @id @default(uuid())
  name                  String        @db.VarChar(200)
  slug                  String        @unique @db.VarChar(220)
  description           String        @db.Text
  curricularContents    String        @map("curricular_contents") @db.Text
  methodology           String        @db.Text
  duration              String        @db.VarChar(200)
  pedagogicalFoundation String        @map("pedagogical_foundation") @db.Text
  status                ProjectStatus @default(DRAFT)
  visibility            Visibility    @default(PRIVATE)
  coverImageUrl         String?       @map("cover_image_url") @db.VarChar(500)
  displayOrder          Int           @default(0) @map("display_order")
  categoryId            String?       @map("category_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  category ProjectCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  members  ProjectMember[]
  records  ProjectRecord[]

  @@index([status])
  @@index([visibility])
  @@index([displayOrder])
  @@index([categoryId])
  @@map("pedagogical_projects")
}

model ProjectMember {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  userId        String   @map("user_id")
  roleInProject String?  @map("role_in_project") @db.VarChar(150)
  createdAt     DateTime @default(now()) @map("created_at")

  project PedagogicalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectRecord {
  id            String       @id @default(uuid())
  projectId     String       @map("project_id")
  title         String       @db.VarChar(200)
  description   String?      @db.Text
  recordDate    DateTime     @map("record_date") @db.Date
  type          RecordType
  visibility    Visibility   @default(PRIVATE)
  status        RecordStatus @default(PENDING_REVIEW)
  createdBy     String       @map("created_by")
  reviewedBy    String?      @map("reviewed_by")
  reviewedAt    DateTime?    @map("reviewed_at")
  reviewComment String?      @map("review_comment") @db.Text
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  project  PedagogicalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author   User               @relation("RecordAuthor", fields: [createdBy], references: [id], onDelete: Restrict)
  reviewer User?              @relation("RecordReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  files    RecordFile[]
  tags     RecordTag[]

  @@index([projectId])
  @@index([createdBy])
  @@index([reviewedBy])
  @@index([visibility, status])
  @@index([recordDate])
  @@map("project_records")
}

model RecordFile {
  id           String     @id @default(uuid())
  recordId     String     @map("record_id")
  fileName     String     @map("file_name") @db.VarChar(255)
  originalName String     @map("original_name") @db.VarChar(255)
  mimeType     String     @map("mime_type") @db.VarChar(150)
  size         BigInt
  storagePath  String     @map("storage_path") @db.VarChar(700)
  publicUrl    String?    @map("public_url") @db.VarChar(700)
  type         FileType
  visibility   Visibility @default(PRIVATE)
  uploadedBy   String     @map("uploaded_by")
  createdAt    DateTime   @default(now()) @map("created_at")

  record   ProjectRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  uploader User          @relation("FileUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([recordId])
  @@index([uploadedBy])
  @@index([visibility])
  @@map("record_files")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String   @db.VarChar(120)
  entityType String   @map("entity_type") @db.VarChar(120)
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ProjectCategory {
  id           String   @id @default(uuid())
  name         String   @unique @db.VarChar(120)
  slug         String   @unique @db.VarChar(140)
  description  String?  @db.Text
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects PedagogicalProject[]

  @@index([displayOrder])
  @@map("project_categories")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  records RecordTag[]

  @@map("tags")
}

model RecordTag {
  id       String @id @default(uuid())
  recordId String @map("record_id")
  tagId    String @map("tag_id")

  record ProjectRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  tag    Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([recordId, tagId])
  @@index([tagId])
  @@map("record_tags")
}
