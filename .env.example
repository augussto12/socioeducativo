# Docker Compose / VPS environment for desdeelpie.com.ar.
# Copy to /home/socioeducativo/.env on the server and replace every placeholder.

DB_PASSWORD=replace-with-long-random-postgres-password

JWT_ACCESS_SECRET=replace-with-long-random-access-secret-64-chars-min
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret-64-chars-min
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

CORS_ORIGIN=https://desdeelpie.com.ar
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

ADMIN_EMAIL=admin@desdeelpie.com.ar
ADMIN_PASSWORD=replace-with-temporary-initial-admin-password

NGINX_PORT=8094

MAX_IMAGE_SIZE=10485760
MAX_DOCUMENT_SIZE=26214400
MAX_AUDIO_SIZE=52428800
MAX_VIDEO_SIZE=262144000
